{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "extraction_schema_v1",
  "title": "StructuredExtractionOutput",
  "description": "Output schema for the JSON extraction task. null_extraction=true signals correct abstention.",
  "type": "object",
  "properties": {
    "null_extraction": {
      "type": "boolean",
      "description": "True when no extractable entities are present in the input."
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name":  { "type": "string" },
          "type":  { "type": "string" },
          "value": { "type": ["string", "number", "boolean", "null"] },
          "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
        },
        "required": ["name", "type", "value"],
        "additionalProperties": false
      }
    }
  },
  "required": ["null_extraction"],
  "if": { "properties": { "null_extraction": { "const": false } } },
  "then": {
    "required": ["entities"],
    "properties": { "entities": { "minItems": 1 } }
  },
  "additionalProperties": false
}
